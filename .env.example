# Copiar a .env.local y completar. NUNCA commitear .env.local.

# --- Neon (Postgres) ---
# Consola de Neon → proyecto → "Connect".
# DATABASE_URL: el connection string POOLED (tiene "-pooler" en el host) — lo usa la app.
# DATABASE_URL_UNPOOLED: el DIRECTO (sin "-pooler") — lo usan las migraciones (drizzle-kit).
DATABASE_URL=
DATABASE_URL_UNPOOLED=


# --- Better Auth ---
# Generar el secret con: npx @better-auth/cli secret   (o: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# URL base de la app: http://localhost:3000 en dev, la URL de Vercel en producción.
BETTER_AUTH_URL=http://localhost:3000
